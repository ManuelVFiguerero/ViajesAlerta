SERPAPI_KEY=tu_serpapi_key

# Precio maximo para alertar (en la moneda elegida)
MAX_PRICE=250

# Defini rutas explicitas ORIGEN-DESTINO separadas por coma
# O usa ORIGIN_AIRPORTS + DESTINATION_AIRPORTS para generar combinaciones.
ROUTES=

# Origenes base
# EZE = Buenos Aires (Ezeiza), AEP = Aeroparque, SCL = Santiago, SJO = San Jose CR
ORIGIN_AIRPORTS=EZE,AEP,SCL,SJO

# Destinos: Centroamerica + Europa + Brasil + USA
# SJO = Costa Rica, GUA = Guatemala, MAD/BCN = Espana, GRU/GIG = Brasil, MIA/JFK = USA
DESTINATION_AIRPORTS=SJO,GUA,MAD,BCN,GRU,GIG,MIA,JFK,LAX

# Filtrar por aerolineas (codigo IATA). Si se deja vacio, busca todas.
# Ejemplos:
# CM = Copa Airlines
# AA = American Airlines
AIRLINES=

# Parametros de busqueda de fechas
START_IN_DAYS=0
DEPARTURE_WINDOW_DAYS=30
DATE_STEP_DAYS=1
TRIP_TYPE=2
FIXED_DEPARTURE_DATE_FROM=
FIXED_DEPARTURE_DATE_TO=
RETURN_DAYS_MIN=30
RETURN_DAYS_MAX=30
RETURN_DAYS_STEP=1
ADULTS=1
NONSTOP_ONLY=false
CURRENCY=USD
GOOGLE_FLIGHTS_GL=us
GOOGLE_FLIGHTS_HL=en
DEEP_SEARCH=false
MAX_RESULTS_PER_DATE=5
REQUEST_THROTTLE_SECONDS=0.8
REQUEST_MAX_PER_RUN=120
# Presupuesto diario opcional. Si >0, limita requests por corrida a este valor.
# Para 250/mes conviene 6 o 7.
DAILY_REQUEST_BUDGET=0
# Si true, rota automaticamente las rutas para ir cambiando dia a dia.
ROTATE_ROUTES_DAILY=false
# Archivo local donde se guarda en que ruta quedo la rotacion.
ROUTE_ROTATION_STATE_FILE=data/route_rotation_state.json
SERPAPI_MAX_RETRIES=4
SERPAPI_BACKOFF_BASE_SECONDS=2

# Promociones (RSS) opcional
SEND_PROMOS=false
PROMO_FEEDS=
PROMO_MAX_ITEMS=5

# Notificaciones por Telegram (gratis)
SEND_TELEGRAM=true
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token
TELEGRAM_CHAT_ID=tu_chat_id

# Notificaciones por email (opcional, desactivado por defecto)
SEND_EMAIL=false
EMAIL_SENDER=tu_correo@gmail.com
EMAIL_PASSWORD=tu_app_password
EMAIL_RECEIVER=destino@correo.com
EMAIL_SUBJECT=Alerta de vuelos baratos
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SSL=true

# Ejecucion continua (cada X horas). Si false, hace una sola corrida.
RUN_FOREVER=false
CHECK_INTERVAL_HOURS=24
