AMADEUS_CLIENT_ID=tu_client_id_de_amadeus
AMADEUS_CLIENT_SECRET=tu_client_secret_de_amadeus

# Precio maximo para alertar (en la moneda elegida)
MAX_PRICE=250

# Defini rutas explicitas ORIGEN-DESTINO separadas por coma
# O usa ORIGIN_AIRPORTS + DESTINATION_AIRPORTS para generar combinaciones.
ROUTES=

# Origenes base
# EZE = Buenos Aires (Ezeiza), AEP = Aeroparque, SCL = Santiago, SJO = San Jose CR
ORIGIN_AIRPORTS=EZE,AEP,SCL,SJO

# Destinos: Centroamerica + Europa + Brasil + USA
# SJO = Costa Rica, GUA = Guatemala, MAD/BCN = Espana, GRU/GIG = Brasil, MIA/JFK = USA
DESTINATION_AIRPORTS=SJO,GUA,MAD,BCN,GRU,GIG,MIA,JFK,LAX

# Filtrar por aerolineas (codigo IATA). Si se deja vacio, busca todas.
# Ejemplos:
# CM = Copa Airlines
# AA = American Airlines
AIRLINES=

# Parametros de busqueda de fechas
START_IN_DAYS=0
DEPARTURE_WINDOW_DAYS=30
DATE_STEP_DAYS=1
ADULTS=1
NONSTOP_ONLY=false
CURRENCY=USD
MAX_RESULTS_PER_DATE=5

# Notificaciones por WhatsApp (Twilio)
SEND_WHATSAPP=true
WHATSAPP_TO=whatsapp:+5492213041688
TWILIO_ACCOUNT_SID=tu_twilio_account_sid
TWILIO_AUTH_TOKEN=tu_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Notificaciones por email (opcional)
SEND_EMAIL=false
EMAIL_SENDER=tu_correo@gmail.com
EMAIL_PASSWORD=tu_app_password
EMAIL_RECEIVER=destino@correo.com
EMAIL_SUBJECT=Alerta de vuelos baratos
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SSL=true

# Ejecucion continua (cada X horas). Si false, hace una sola corrida.
RUN_FOREVER=false
CHECK_INTERVAL_HOURS=24
